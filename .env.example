# Auto-generate this file by running: ./scripts/dev-setup.sh <your-name>
# Or manually fill in the values below.

# AWS credentials (from `aws configure`)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# Cognito (from Terraform outputs)
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# DynamoDB
DYNAMODB_USERS_TABLE=consumer-ordering-users
DYNAMODB_PLANS_TABLE=consumer-ordering-plans
DYNAMODB_ORDERS_TABLE=consumer-ordering-orders

# SQS (from Terraform outputs)
SQS_ORDER_EVENTS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/consumer-ordering-dev-order-events
